# Database (Turso)
# Local development: use file:./local.db with "local" as auth token
# Production: use libsql://<db-name>-<org>.turso.io with a real auth token
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=local

# AI Recipe Parsing (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Vercel (only needed for CI/CD, not local dev)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# Turso Platform API (only needed for CI/CD branch databases)
# TURSO_API_TOKEN=
# TURSO_ORG_NAME=
# TURSO_PRIMARY_DB_NAME=
